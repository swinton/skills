#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "PyYAML==6.0.2",
# ]
# ///
"""Validate repository skill structure and evaluation cases."""

from __future__ import annotations

import re
from pathlib import Path
from typing import Any

import yaml


ROOT = Path(__file__).resolve().parent.parent
SKILLS_DIR = ROOT / "skills"
SKILL_NAME = re.compile(r"^[a-z0-9]+(?:-[a-z0-9]+)*$")
CASE_ID = SKILL_NAME


def load_yaml(text: str) -> Any:
    return yaml.safe_load(text)


def validate_frontmatter(path: Path, expected_name: str) -> None:
    text = path.read_text()
    if not text.startswith("---\n"):
        raise ValueError("missing YAML frontmatter")
    closing = text.find("\n---\n", 4)
    if closing < 0:
        raise ValueError("unterminated YAML frontmatter")
    metadata = load_yaml(text[4:closing])
    if not isinstance(metadata, dict):
        raise ValueError("frontmatter must be a mapping")
    if metadata.get("name") != expected_name:
        raise ValueError("metadata name does not match directory name")


def validate_cases(path: Path) -> None:
    document = load_yaml(path.read_text())
    if not isinstance(document, dict):
        raise ValueError("document must be a mapping")
    cases = document.get("cases")
    if not isinstance(cases, list) or not cases:
        raise ValueError("cases must be a non-empty list")
    seen: set[str] = set()
    required = ("id", "description", "prompt", "expected", "invariants")
    for index, case in enumerate(cases, start=1):
        if not isinstance(case, dict):
            raise ValueError(f"case {index} must be a mapping")
        for key in required:
            value = case.get(key)
            if value is None:
                raise ValueError(f"case {index}: missing {key}")
            if hasattr(value, "__len__") and len(value) == 0:
                raise ValueError(f"case {index}: empty {key}")
        invariants = case["invariants"]
        if not isinstance(invariants, list) or not invariants or not all(
            isinstance(item, str) and item for item in invariants
        ):
            raise ValueError(
                f"case {index}: invariants must be a non-empty list of strings"
            )
        case_id = case["id"]
        if not isinstance(case_id, str) or not CASE_ID.fullmatch(case_id):
            raise ValueError(f"case {index}: id must use lowercase kebab-case")
        if case_id in seen:
            raise ValueError(f"duplicate case id {case_id!r}")
        seen.add(case_id)


def main() -> int:
    if not SKILLS_DIR.is_dir():
        print(f"error: missing skills directory: {SKILLS_DIR}")
        return 1

    errors: list[str] = []
    paths = sorted(SKILLS_DIR.iterdir())
    if not paths:
        errors.append("no skills found")

    for path in paths:
        if not path.is_dir():
            errors.append(f"every immediate child of skills/ must be a directory: {path}")
            continue
        name = path.name
        if not SKILL_NAME.fullmatch(name):
            errors.append(f"invalid skill name {name!r}; use lowercase kebab-case")

        skill_file = path / "SKILL.md"
        if not skill_file.is_file() or not skill_file.stat().st_size:
            errors.append(f"{name}: missing or empty SKILL.md")
        else:
            try:
                validate_frontmatter(skill_file, name)
            except (OSError, UnicodeError, ValueError, yaml.YAMLError):
                errors.append(
                    f"{name}: invalid SKILL.md frontmatter or mismatched metadata name"
                )

        if not (path / "README.md").is_file():
            errors.append(f"{name}: missing README.md")
        experimental = path / "EXPERIMENTAL.md"
        if experimental.exists() and (
            not experimental.is_file() or not experimental.stat().st_size
        ):
            errors.append(f"{name}: EXPERIMENTAL.md must be a non-empty file")

        evals = path / "evals"
        if evals.is_dir():
            for case_file in sorted((*evals.glob("*.yaml"), *evals.glob("*.yml"))):
                try:
                    validate_cases(case_file)
                except (OSError, UnicodeError, ValueError, yaml.YAMLError):
                    relative = case_file.relative_to(ROOT)
                    errors.append(f"{name}: invalid evaluation schema in {relative}")

    if errors:
        for error in errors:
            print(f"error: {error}")
        print(f"validation failed with {len(errors)} error(s)")
        return 1
    print("validation passed")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
