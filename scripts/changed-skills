#!/usr/bin/env python3
"""List skill directories affected by a Git comparison."""

from __future__ import annotations

import argparse
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
SKILLS_DIR = ROOT / "skills"
GLOBAL_PATHS = {
    ".github/workflows/agent-security.yml",
    "scripts/changed-skills",
}


def all_skills() -> list[str]:
    return sorted(path.name for path in SKILLS_DIR.iterdir() if path.is_dir())


def changed_paths(ref: str) -> list[str]:
    process = subprocess.run(
        ["git", "diff", "--name-only", f"{ref}...HEAD"],
        cwd=ROOT,
        capture_output=True,
        text=True,
        check=False,
    )
    if process.returncode:
        sys.exit(f"error: could not inspect changes since {ref}: {process.stderr.strip()}")
    return [line.strip() for line in process.stdout.splitlines() if line.strip()]


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--changed-since",
        metavar="REF",
        help="List only skills affected since Git REF; omit to list all skills",
    )
    args = parser.parse_args()

    if not args.changed_since:
        skills = all_skills()
    else:
        paths = changed_paths(args.changed_since)
        if any(path in GLOBAL_PATHS for path in paths):
            skills = all_skills()
        else:
            changed = {
                parts[1]
                for path in paths
                if len(parts := Path(path).parts) >= 3 and parts[0] == "skills"
            }
            skills = sorted(
                skill for skill in changed if (SKILLS_DIR / skill).is_dir()
            )

    for skill in skills:
        print(f"skills/{skill}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
