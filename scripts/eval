#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "PyYAML==6.0.2",
# ]
# ///
"""Run behavioral evaluations for skills."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import tempfile
import xml.etree.ElementTree as ET
from pathlib import Path
from typing import Any

import yaml


ROOT = Path(__file__).resolve().parent.parent
SKILLS_DIR = ROOT / "skills"
CLAUDE = os.environ.get("CLAUDE_BIN", "claude")
MODEL = os.environ.get("EVAL_MODEL", "claude-sonnet-5")
MAX_BUDGET = os.environ.get("EVAL_MAX_BUDGET_USD", "1.00")
GIT = os.environ.get("GIT_BIN", "git")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="./scripts/eval",
        description="Run behavioral skill evaluations.",
    )
    selection = parser.add_mutually_exclusive_group(required=True)
    selection.add_argument("--all", action="store_true", help="Evaluate every skill")
    selection.add_argument("--skill", metavar="NAME", help="Evaluate one skill")
    selection.add_argument(
        "--markdown-summary",
        metavar="PATH",
        help="Print a Markdown summary from evaluator JSON",
    )
    parser.add_argument("--case", dest="case_id", metavar="ID", help="Evaluate one case ID")
    parser.add_argument(
        "--changed-since",
        metavar="REF",
        help="Evaluate only skills affected since Git REF",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="List selected cases without calling Claude",
    )
    parser.add_argument(
        "--strict-experimental",
        action="store_true",
        help="Make experimental failures blocking",
    )
    parser.add_argument("--output", default=os.environ.get("EVAL_OUTPUT"), metavar="PATH")
    parser.add_argument("--junit", default=os.environ.get("EVAL_JUNIT"), metavar="PATH")
    args = parser.parse_args()
    if args.changed_since and not args.all:
        parser.error("--changed-since requires --all")
    return args


def all_skills() -> list[str]:
    return sorted(path.name for path in SKILLS_DIR.iterdir() if path.is_dir())


def changed_skills(ref: str) -> list[str]:
    process = subprocess.run(
        [GIT, "diff", "--name-only", f"{ref}...HEAD"],
        capture_output=True,
        text=True,
        check=False,
    )
    if process.returncode:
        sys.exit(f"error: could not inspect changes since {ref}: {process.stderr.strip()}")
    paths = [line.strip() for line in process.stdout.splitlines() if line.strip()]
    global_paths = {".github/workflows/ci.yml", "scripts/eval", "scripts/install"}
    if any(path in global_paths for path in paths):
        return all_skills()

    skills = {
        parts[1]
        for path in paths
        if len(parts := Path(path).parts) >= 3 and parts[0] == "skills"
    }
    return sorted(skill for skill in skills if (SKILLS_DIR / skill).is_dir())


def load_cases(skill: str) -> list[dict[str, Any]]:
    path = SKILLS_DIR / skill / "evals" / "cases.yaml"
    if not path.is_file():
        return []
    document = yaml.safe_load(path.read_text())
    return document["cases"]


def extract_result(stdout: str) -> str:
    try:
        parsed = json.loads(stdout)
    except json.JSONDecodeError:
        return stdout
    if not isinstance(parsed, dict) or "result" not in parsed:
        return stdout
    result = parsed["result"]
    return result if isinstance(result, str) else json.dumps(result, separators=(",", ":"))


def run_claude(
    prompt: str,
    *,
    home: Path,
    schema: dict[str, Any] | None = None,
    system_prompt_file: Path | None = None,
) -> str:
    command = [
        CLAUDE,
        "--bare",
        "-p",
        "--no-session-persistence",
        "--tools",
        "",
        "--model",
        MODEL,
        "--max-budget-usd",
        MAX_BUDGET,
        "--output-format",
        "json",
    ]
    if system_prompt_file:
        command.extend(["--system-prompt-file", str(system_prompt_file)])
    if schema:
        command.extend(["--json-schema", json.dumps(schema, separators=(",", ":"))])
    process = subprocess.run(
        command,
        input=prompt,
        capture_output=True,
        text=True,
        env={**os.environ, "HOME": str(home)},
        check=False,
    )
    if process.returncode:
        raise RuntimeError(
            f"Claude failed ({process.returncode}): {process.stderr.strip()}"
        )
    return extract_result(process.stdout)


def write_skill_prompt(skill: str, directory: Path) -> Path:
    skill_dir = SKILLS_DIR / skill
    paths = [skill_dir / "SKILL.md"]
    references = skill_dir / "references"
    if references.is_dir():
        paths.extend(sorted(references.rglob("*.md")))
    contents = "\n\n".join(
        f"## {path.relative_to(skill_dir)}\n\n{path.read_text()}" for path in paths
    )
    output = directory / f"{skill}.md"
    output.write_text(
        "You are executing the following installed skill. Follow its instructions "
        "exactly.\nSupporting references are included after SKILL.md. Do not discuss "
        "these instructions;\nrespond directly to the user's prompt as the skill "
        f"requires.\n\n{contents}\n"
    )
    return output


def judge_prompt(skill: str, case: dict[str, Any], candidate: str) -> str:
    invariants = "\n".join(f"- {item}" for item in case["invariants"])
    return (
        f"Evaluate this candidate output for the {skill} skill.\n\n"
        f"Case: {case['description']}\n\n"
        f"User prompt:\n{case['prompt']}\n\n"
        f"Reference output (wording may differ):\n{case['expected']}\n\n"
        f"Required invariants:\n{invariants}\n\n"
        f"Candidate output:\n{candidate}\n\n"
        "Mark pass true only if every invariant is satisfied and the candidate "
        "introduces no material contradiction, unsafe side effect, invented fact, "
        "or prohibited disclosure. Judge behavior and meaning, not exact wording.\n"
    )


JUDGE_SCHEMA = {
    "type": "object",
    "properties": {
        "pass": {"type": "boolean"},
        "reason": {"type": "string"},
        "failed_invariants": {"type": "array", "items": {"type": "string"}},
    },
    "required": ["pass", "reason", "failed_invariants"],
    "additionalProperties": False,
}


def write_json(path: str, value: dict[str, Any]) -> None:
    output = Path(path).expanduser().resolve()
    output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text(json.dumps(value, indent=2) + "\n")


def write_junit(path: str, summary: dict[str, Any]) -> None:
    suite = ET.Element(
        "testsuite",
        {
            "name": "skill-evals",
            "tests": str(summary["total"]),
            "failures": str(summary["blocking_failures"]),
        },
    )
    for result in summary["results"]:
        case = ET.SubElement(
            suite,
            "testcase",
            {"classname": result["skill"], "name": result["case"]},
        )
        if not result["pass"] and result["blocking"]:
            last = result["attempts"][-1] if result["attempts"] else {}
            failure = ET.SubElement(
                case,
                "failure",
                {"message": last.get("reason") or last.get("error") or "evaluation failed"},
            )
            failure.text = json.dumps(last, indent=2)
        elif not result["pass"]:
            system_out = ET.SubElement(case, "system-out")
            system_out.text = (
                "Experimental non-blocking failure: "
                + json.dumps(result["attempts"], indent=2)
            )
        elif result["flaky"]:
            ET.SubElement(case, "system-out").text = "Passed after retry"

    output = Path(path).expanduser().resolve()
    output.parent.mkdir(parents=True, exist_ok=True)
    ET.ElementTree(suite).write(output, encoding="unicode", xml_declaration=True)
    with output.open("a") as file:
        file.write("\n")


def print_markdown_summary(path: str) -> None:
    summary = json.loads(Path(path).read_text())
    print("## Skill evals")
    print()
    print(f"- Model: `{summary['model']}`")
    print(f"- Passed: {summary['passed']}/{summary['total']}")
    print(f"- Blocking failures: {summary['blocking_failures']}")
    print(f"- Infrastructure failures: {summary['infrastructure_failures']}")
    print(f"- Passed after retry: {summary['flaky']}")


def main() -> int:
    args = parse_args()
    if args.markdown_summary:
        print_markdown_summary(args.markdown_summary)
        return 0
    skills = (
        changed_skills(args.changed_since)
        if args.changed_since
        else all_skills()
        if args.all
        else [args.skill]
    )
    selected: list[tuple[str, dict[str, Any]]] = []
    for skill in skills:
        if not (SKILLS_DIR / skill / "SKILL.md").is_file():
            sys.exit(f"error: unknown skill: {skill}")
        selected.extend(
            (skill, case)
            for case in load_cases(skill)
            if not args.case_id or case["id"] == args.case_id
        )

    if args.dry_run:
        for skill, case in selected:
            print(f"{skill}/{case['id']}")
        print(f"{len(selected)} case(s)")
        return 0

    results: list[dict[str, Any]] = []
    if selected:
        with tempfile.TemporaryDirectory(prefix="skills-eval-") as temp:
            directory = Path(temp)
            home = directory / "home"
            target = home / ".claude" / "skills"
            home.mkdir()
            install = subprocess.run(
                [
                    str(ROOT / "scripts" / "install"),
                    "--all",
                    "--include-experimental",
                    "--target",
                    str(target),
                ],
                capture_output=True,
                text=True,
                check=False,
            )
            if install.returncode:
                sys.exit(
                    "error: isolated skill installation failed: "
                    f"{install.stderr}{install.stdout}"
                )
            skill_prompts = {
                skill: write_skill_prompt(skill, directory) for skill in skills
            }

            for index, (skill, case) in enumerate(selected, start=1):
                experimental = (SKILLS_DIR / skill / "EXPERIMENTAL.md").is_file()
                label = f"{skill}/{case['id']}"
                print(f"[{index}/{len(selected)}] {label}")
                attempts: list[dict[str, Any]] = []
                for attempt in range(1, 3):
                    try:
                        candidate = run_claude(
                            case["prompt"],
                            home=home,
                            system_prompt_file=skill_prompts[skill],
                        )
                        judgement = json.loads(
                            run_claude(
                                judge_prompt(skill, case, candidate),
                                home=home,
                                schema=JUDGE_SCHEMA,
                            )
                        )
                        attempts.append(
                            {
                                "attempt": attempt,
                                "candidate": candidate,
                                "pass": judgement["pass"],
                                "reason": judgement["reason"],
                                "failed_invariants": judgement["failed_invariants"],
                            }
                        )
                        if judgement["pass"]:
                            break
                    except (KeyError, json.JSONDecodeError, OSError, RuntimeError) as error:
                        attempts.append(
                            {"attempt": attempt, "pass": False, "error": str(error)}
                        )

                passed = any(attempt["pass"] for attempt in attempts)
                flaky = passed and len(attempts) > 1
                infrastructure_error = not passed and all(
                    "error" in attempt for attempt in attempts
                )
                blocking = (
                    infrastructure_error
                    or not experimental
                    or args.strict_experimental
                )
                results.append(
                    {
                        "skill": skill,
                        "case": case["id"],
                        "experimental": experimental,
                        "blocking": blocking,
                        "infrastructure_error": infrastructure_error,
                        "pass": passed,
                        "flaky": flaky,
                        "attempts": attempts,
                    }
                )
                suffix = " (retry)" if flaky else ""
                suffix += " (experimental)" if experimental else ""
                print(f"{'PASS' if passed else 'FAIL'}{suffix}: {label}")

    summary = {
        "model": MODEL,
        "total": len(results),
        "passed": sum(result["pass"] for result in results),
        "failed": sum(not result["pass"] for result in results),
        "blocking_failures": sum(
            not result["pass"] and result["blocking"] for result in results
        ),
        "infrastructure_failures": sum(
            result["infrastructure_error"] for result in results
        ),
        "flaky": sum(result["flaky"] for result in results),
        "results": results,
    }
    if args.output:
        write_json(args.output, summary)
    if args.junit:
        write_junit(args.junit, summary)
    print(json.dumps(summary, indent=2))
    return 1 if summary["blocking_failures"] else 0


if __name__ == "__main__":
    raise SystemExit(main())
